# Copy this file to .env.production and replace every change-me value before deployment.

# Public access
HTTP_PORT=80

# Persistent data disk
DATA_ROOT=/data

# Application authentication
API_KEY=change-me-api-key
ADMIN_KEY=change-me-admin-key

# PostgreSQL
POSTGRES_USER=filecodebox
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=filecodebox
DB_HOST=postgres

# MinIO / S3-compatible storage
MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://your-server-ip:9000
S3_BUCKET=uploads
S3_REGION=us-east-1

# Backend
BACKEND_PORT=8080
TUSD_UPLOAD_DIR=/data/uploads
SHARE_CODE_TTL_MINUTES=120
SHARE_CODE_MAX_DOWNLOADS=10000
CORS_ORIGINS=http://your-server-ip
ENABLE_DEBUG_ENDPOINTS=false
